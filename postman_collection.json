							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"capacity\": 200,\n  \"is_active\": true\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/venues/my-awesome-venue",
							"host": ["{{baseUrl}}"],
							"path": ["venues", "my-awesome-venue"]
