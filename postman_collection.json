		{
			"name": "Events",
			"item": [
				{
					"name": "Get All Events",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events?page=1&per_page=10",
							"host": ["{{baseUrl}}"],
							"path": ["events"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "per_page", "value": "10" },
								{ "key": "search", "value": "", "disabled": true }
							]
						},
						"description": "List all events (public). Optional: `search` param filters by name."
					},
					"response": []
				},
				{
					"name": "Get Event by Slug",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events/go-conference-2026",
							"host": ["{{baseUrl}}"],
							"path": ["events", "go-conference-2026"]
						},
						"description": "Get event detail with venue, guests, and prices (public)."
					},
					"response": []
				},
				{
					"name": "Create Event",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"venue_id\": 1,\n  \"name\": \"My Awesome Event\",\n  \"description\": \"This is a description of my awesome event.\",\n  \"event_start_at\": \"2026-06-15T09:00:00Z\",\n  \"status\": \"DRAFT\",\n  \"sales_start_date\": \"2026-05-01T00:00:00Z\",\n  \"sales_end_date\": \"2026-06-14T23:59:59Z\",\n  \"guests\": [\n    {\n      \"guest_id\": 1,\n      \"session_title\": \"Introduction to Go\"\n    }\n  ],\n  \"prices\": [\n    {\n      \"name\": \"Presale\",\n      \"price\": 100000,\n      \"quota\": 100\n    },\n    {\n      \"name\": \"Regular\",\n      \"price\": 150000,\n      \"quota\": 200\n    }\n  ]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/events",
							"host": ["{{baseUrl}}"],
							"path": ["events"]
						},
						"description": "Create a new event with guests and ticket prices.\n\n**Prerequisites:** venue and guests must exist.\n**`venue_id`**: from GET /venues\n**`guest_id`**: from GET /guests\n**Total capacity** (sum of prices[].quota) must not exceed venue capacity.\n**Auth:** administrator or organizer."
					},
					"response": []
				},
				{
					"name": "Update Event",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"description\": \"Updated description for the event.\",\n  \"status\": \"PUBLISHED\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/events/my-awesome-event",
							"host": ["{{baseUrl}}"],
							"path": ["events", "my-awesome-event"]
						},
						"description": "Update an event. All fields optional.\n\n**Valid statuses:** `DRAFT`, `PUBLISHED`, `CANCELLED`\n**Auth:** administrator or organizer."
					},
					"response": []
				}
			]
