						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"event_id\": \"1\",\n  \"tickets_ordered\": [\n    {\n      \"price_id\": \"1\",\n      \"quantity\": 2\n    }\n  ]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/orders",
							"host": ["{{baseUrl}}"],
							"path": ["orders"]
						},
						"description": "Create a new order for event tickets.\n\n**Prerequisites:** event and event prices must exist.\n`event_id`: event ID from GET /events\n`price_id`: event price ID from GET /events/:slug response\n**Auth:** attendee. Rate limited: 10/min.\n**Max:** 10 line items, 10 quantity per item."
					},
					"response": []
				},
				{
					"name": "Cancel Order",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Changed my mind\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/orders/1",
							"host": ["{{baseUrl}}"],
							"path": ["orders", "1"]
						},
						"description": "Cancel an order before payment. Only the order owner can cancel."
					},
					"response": []
				}
			]
		},
		{
			"name": "Payments",
			"item": [
				{
					"name": "Create Payment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"order_id\": 1,\n  \"payment_method\": \"BANK_TRANSFER_BCA\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/payments",
							"host": ["{{baseUrl}}"],
							"path": ["payments"]
						},
						"description": "Create a payment for an order.\n\n**Valid payment_methods:**\n- `BANK_TRANSFER_BCA`\n- `BANK_TRANSFER_BNI`\n- `BANK_TRANSFER_BRI`\n- `CREDIT_CARD`\n- `VIRTUAL_ACCOUNT`\n- `GOPAY`\n- `INDOMARET`\n- `PAYPAL`\n\n**Auth:** any verified user. Rate limited: 10/min."
					},
					"response": []
				},
				{
					"name": "Get Payment by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/payments/1",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "1"]
						},
						"description": "Get payment details by payment ID. **Auth:** any verified user."
					},
					"response": []
				},
				{
					"name": "Get Payment by Order ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/payments/order/1",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "order", "1"]
						},
						"description": "Get payment details by order ID. **Auth:** any verified user."
					},
					"response": []
				},
				{
					"name": "Update Payment",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"payment_method\": \"BANK_TRANSFER_BNI\",\n  \"amount\": 250000\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/payments/1",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "1"]
						},
						"description": "Update payment details. All fields optional.\n\nFields: `payment_method`, `transaction_id`, `amount`, `payment_status`\n**Auth:** any verified user."
					},
					"response": []
				},
				{
					"name": "Update Payment Status (to SUCCESS)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"SUCCESS\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/payments/1/status",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "1", "status"]
						},
						"description": "Update payment status.\n\n**Valid statuses:** `PENDING`, `SUCCESS`, `FAILED`, `REFUNDED`\n**Transitions:** PENDING → SUCCESS|FAILED; SUCCESS → REFUNDED; FAILED/REFUNDED are terminal.\n\n**SUCCESS triggers:** order marked PAID + tickets generated with QR codes.\n**Auth:** any verified user. Rate limited: 20/min."
					},
					"response": []
				},
				{
					"name": "Delete Payment",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/payments/1",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "1"]
						},
						"description": "Delete a payment. **Auth:** any verified user."
					},
					"response": []
				},
				{
					"name": "Midtrans Notification (Webhook)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"order_id\": \"ORDER-123\",\n  \"transaction_status\": \"settlement\",\n  \"fraud_status\": \"accept\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/payments/midtrans-notification",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "midtrans-notification"]
						},
						"description": "Public webhook for Midtrans payment gateway. No auth required. Rate limited: 60/min."
					},
					"response": []
				}
			]
		},
		{
			"name": "Tickets",
			"item": [
				{
					"name": "Check-In Ticket",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"ticket_code\": \"aBcDeFgHiJ\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/tickets/check-in",
							"host": ["{{baseUrl}}"],
							"path": ["tickets", "check-in"]
						},
						"description": "Scan/check-in a ticket using its unique ticket code.\n\n**Requirements:**\n- Order must be PAID\n- Ticket must not have been scanned before\n\n**Response includes:** ticket details, owner info, order status.\n\n**Auth:** administrator or organizer. Rate limited: 120/min.\n\n> To get ticket codes: query `SELECT ticket_code FROM tickets;` or check `./storage/qrcodes/` folder."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api/v1"
		}
	]
}
